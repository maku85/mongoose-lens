{
  "name": "mongoose-lens",
  "version": "0.1.0",
  "description": "Slow query interceptor and index advisor for Mongoose 8+",
  "license": "MIT",
  "keywords": ["mongoose", "mongodb", "slow-query", "performance", "index", "explain"],
  "sideEffects": false,
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "author": "makuma85@gmail.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/maku85/mongoose-lens.git"
  },
  "bugs": {
    "url": "https://github.com/maku85/mongoose-lens/issues"
  },
  "homepage": "https://github.com/maku85/mongoose-lens#readme",
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node scripts/postbuild.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc -p tsconfig.esm.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "format": "biome format --write src test",
    "prepublishOnly": "pnpm run build && pnpm test"
  },
  "peerDependencies": {
    "mongoose": "^8.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "mongoose": "^8.9.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
